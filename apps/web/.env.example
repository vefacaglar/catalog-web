# Server-side fetch icin API adresi
API_URL=http://localhost:3001
# Tarayicidan (admin UI) erisim icin
NEXT_PUBLIC_API_URL=http://localhost:3001
# ImageKit URL endpoint (ör. https://ik.imagekit.io/<id>)
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
# E.164 formatinda iletisim telefonu (ör. +905321234567)
NEXT_PUBLIC_CONTACT_PHONE=+900000000000
# API'nin revalidate webhook'u icin ortak sir — apps/api/.env ile ayni olmali
REVALIDATE_SECRET=change-me-revalidate-secret
