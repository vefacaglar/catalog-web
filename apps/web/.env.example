# API base URL for server-side fetches
API_URL=http://localhost:3001
# API base URL for browser requests (admin UI)
NEXT_PUBLIC_API_URL=http://localhost:3001
# ImageKit URL endpoint (e.g. https://ik.imagekit.io/<id>)
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
# Contact phone number in E.164 format (e.g. +905321234567)
NEXT_PUBLIC_CONTACT_PHONE=
# Public site URL used for metadata and sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Shared secret for the revalidation webhook — must match apps/api/.env
REVALIDATE_SECRET=change-me-revalidate-secret
