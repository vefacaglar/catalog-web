NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://catalog:catalog@localhost:5432/catalog
JWT_SECRET=change-me-jwt-secret-32-chars-min
COOKIE_SECRET=change-me-cookie-secret-32-chars
WEB_ORIGIN=http://localhost:3000
REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=change-me-revalidate-secret

# ImageKit credentials (required for image uploads — from the https://imagekit.io dashboard)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
