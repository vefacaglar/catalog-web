{
  "name": "catalog-web",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@catalog/db",
    "db:migrate": "turbo run db:migrate --filter=@catalog/db",
    "db:seed": "turbo run db:seed --filter=@catalog/db",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.5.0"
  }
}
